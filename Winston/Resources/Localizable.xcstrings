    "Looks up covers and details from free catalogs (Open Library, Google Books) for imported books, filling in only what's missing. When off, Winston stays fully offline and uses the metadata embedded in your files." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "U importovaných knih vyhledá obálky a údaje ze svobodných katalogů (Open Library, Google Books) a doplní jen to, co chybí. Když je vypnuto, Winston zůstává plně offline a používá metadata vložená ve vašich souborech."
          }
        }
      }
    },
    "Make Preferred" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavit jako preferované"
          }
        }
      }
    },
    "Make Primary" : {
